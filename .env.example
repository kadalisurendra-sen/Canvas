# =============================================================================
# Helio Canvas Admin Panel - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# All values shown are safe defaults for local development.
# =============================================================================

# Application
APP_NAME=Helio Canvas
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
APP_PORT=8000

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=db_platform
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/db_platform

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=helio
KEYCLOAK_CLIENT_ID=helio-admin
KEYCLOAK_CLIENT_SECRET=change-me-in-production
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# JWT
JWT_ALGORITHM=RS256
JWT_AUDIENCE=helio-admin

# CORS
CORS_ORIGINS=["http://localhost:5173"]
